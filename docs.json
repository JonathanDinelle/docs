{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Veval",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["quickstart"]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/tracing",
          "guides/scenarios",
          "guides/assertions",
          "guides/replay",
          "guides/snapshots"
        ]
      },
      {
        "group": "Reference",
        "pages": ["llm-reference"]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://dashboard.veval.dev",
          "icon": "chart-line"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.veval.dev"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
